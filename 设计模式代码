}
中介者模式：public abstract class Mediator {
    public abstract void contact(String msg,Colleague colleague);
}

public abstract class Colleague {
    protected Mediator mediator;
    public Colleague(Mediator mediator){
        this.mediator=mediator;
    }
    public abstract void receive(String msg);
}

public class ConcreteMediator extends Mediator {
    private Colleague c1;
    private Colleague c2;
    public void setC1(Colleague c1){
        this.c1=c1;
    }
    public void setC2(Colleague c2){
        this.c2=c2;
    }
    @Override
    public void contact(String msg,Colleague colleague){
        if(colleague==c1){
            c2.receive(msg);
        }else{
            c1.receive(msg);
        }
    }
}
public class ConcreteColleagueA extends Colleague {
    public ConcreteColleagueA(Mediator mediator) {
        super(mediator);
    }
    public void send(String msg){
        mediator.contact(msg,this);
    }
    @Override
    public void receive(String msg){
    }
}
public class ConcreteColleagueB extends Colleague {
    public ConcreteColleagueB(Mediator mediator) {
        super(mediator);
    }
    public void send(String msg){
        mediator.contact(msg,this);
    }
    @Override
    public void receive(String msg){
    }
}
